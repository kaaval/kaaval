# ── Kaaval — environment configuration ─────────────────────────────────────────
# For docker-compose deployments, copy it next to the compose file (compose
# loads `.env` from its own directory):
#
#   cp .env.example deploy/.env
#   cd deploy && docker compose up -d
#
# Every variable has a working development default. Variables marked
# "REQUIRED in production" must be set before any real deployment.

# ── Database ────────────────────────────────────────────────────────────────────

# Password for the bundled PostgreSQL container. Compose injects it into both
# the postgres service and the control-plane's DATABASE_URL.
# REQUIRED in production — the default is for local development only.
POSTGRES_PASSWORD=password

# Full SQLAlchemy/libpq connection string. Only needed when running the
# control plane OUTSIDE compose (e.g. `make dev-api`) or pointing at an
# external PostgreSQL. Inside compose it is derived from POSTGRES_PASSWORD.
# Default (bare local runs): postgresql://kaaval:password@127.0.0.1:5432/kaaval_db
#DATABASE_URL=postgresql://kaaval:password@127.0.0.1:5432/kaaval_db

# ── Control plane — auth secrets ────────────────────────────────────────────────

# HMAC keys signing JWT access and refresh tokens (HS256).
# REQUIRED in production — generate each with: openssl rand -hex 32
KAAVAL_SECRET_KEY=change_me_in_prod
KAAVAL_REFRESH_SECRET_KEY=change_me_refresh_in_prod

# Password for the `admin` user seeded on first startup. Optional: when unset,
# a random password is generated and printed once to the control-plane logs.
#KAAVAL_ADMIN_PASSWORD=

# ── Control plane — networking ──────────────────────────────────────────────────

# URL the dashboard is served from; used to build the CORS allowlist.
FRONTEND_URL=http://localhost:3000

# Comma-separated CORS allowlist override. Optional: defaults to
# "<FRONTEND_URL>,http://localhost:3001".
#ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Dashboard ───────────────────────────────────────────────────────────────────

# Control-plane API base URL as seen from the BROWSER (NEXT_PUBLIC_* values are
# baked into the client bundle at build time). Set to your API's public URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Cloud scanner (compose profile: scanner) ────────────────────────────────────

# Directory of integration extensions loaded by the scanner. The compose file
# mounts ../extensions into the container and sets this automatically.
#EXTENSIONS_DIR=/app/extensions/integrations

# Internal: correlation id passed by the control plane when it triggers a scan
# run. Not meant to be set by hand.
#KAAVAL_SCAN_ID=

# ── Agent ───────────────────────────────────────────────────────────────────────

# Enrollment token for kaaval-agent when connecting to the control plane
# (fallback for the --token flag).
#KAAVAL_TOKEN=

# ── Optional observability (compose profile: observability) ─────────────────────

# ClickHouse password for the eBPF/syslog time-series store.
# REQUIRED if you enable the observability profile in production.
CLICKHOUSE_PASSWORD=password
